<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>CSharpier.Core</id>
    <version>0.27.0</version>
    <authors>CSharpier</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>logo.png</icon>
    <readme>README.md</readme>
    <description>CSharpier is an opinionated code formatter for c#.</description>
    <repository type="git" url="https://github.com/belav/csharpier" commit="7d091735598cd1d3f81953f8c6ca35c75b48123a" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.8.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Abstractions" version="20.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.8.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Abstractions" version="20.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.8.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Abstractions" version="20.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="4.8.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Abstractions" version="20.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="8.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>